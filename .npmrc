# Skip dependency install/build scripts.
#
# MindAR pulls in the native `canvas` package (used only by its OFFLINE .mind
# compiler, which this app never runs). Compiling canvas requires system build
# tools that aren't present on Vercel's build image (or this Windows machine),
# so its node-gyp step fails the install. The browser app and `npm run build`
# never need canvas, so we skip install scripts entirely.
#
# This is safe here because every package we actually build with (Vite/Rolldown,
# @napi-rs/canvas for the offline asset scripts) ships prebuilt binaries via
# platform-specific optional dependencies — none need a build script to work.
ignore-scripts=true
